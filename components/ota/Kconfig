menu "HAPanel OTA"

    config HAPANEL_OTA_SELF_TEST_STAGE_FACTORY_ON_BOOT
        bool "Stage factory image into OTA slot on boot for self-test"
        default n
        help
            Development-only bring-up switch. When enabled, a boot from the
            factory partition copies the running app image into the next OTA
            slot through the normal OTA session API and sets that slot as the
            next boot target.

            The panel does not restart automatically. Leave this disabled for
            normal firmware builds.

    config HAPANEL_OTA_MQTT_SELF_TEST_STAGE_ENABLE
        bool "Enable MQTT-triggered OTA self-test staging"
        default n
        help
            Development-only bring-up switch. When enabled, MQTT can trigger a
            local OTA self-test that copies the currently running app image into
            the inactive OTA slot and sets that slot as the next boot target.

            This writes flash and changes the next boot partition, but it does
            not restart the panel automatically. Leave this disabled for normal
            firmware builds.

endmenu

menu "HAPanel MQTT"

    config HAPANEL_MQTT_BROKER_URI
        string "MQTT broker URI"
        default ""
        help
            Optional MQTT broker URI for early Home Assistant bring-up, for
            example mqtt://192.168.1.10:1883. Leave empty until runtime
            provisioning exists.

    config HAPANEL_MQTT_CLIENT_ID
        string "MQTT client ID"
        default "hapanel"
        help
            MQTT client identifier used when connecting to the broker.

    config HAPANEL_MQTT_USERNAME
        string "MQTT username"
        default ""
        help
            Optional MQTT username. Avoid committing local credentials into
            sdkconfig defaults.

    config HAPANEL_MQTT_PASSWORD
        string "MQTT password"
        default ""
        help
            Optional MQTT password. Avoid committing local credentials into
            sdkconfig defaults.

    config HAPANEL_MQTT_AVAILABILITY_TOPIC
        string "MQTT availability topic"
        default "hapanel/status"
        help
            Retained availability topic used for early Home Assistant bring-up.
            The panel publishes "online" when connected and configures a last
            will of "offline".

    config HAPANEL_MQTT_DEVICE_STATUS_TOPIC
        string "MQTT device status topic"
        default "hapanel/device/status"
        help
            Retained JSON topic with a minimal structured device status payload.
            This is the stable foundation for future Home Assistant discovery.

    config HAPANEL_MQTT_DEVICE_STATE_TOPIC
        string "MQTT device state topic"
        default "hapanel/device/state"
        help
            Retained JSON topic with live panel state such as service statuses,
            runtime revision, uptime, and PSRAM readiness.

    config HAPANEL_MQTT_COMMAND_TOPIC
        string "MQTT command topic"
        default "hapanel/device/command"
        help
            Non-retained command topic for safe foundation-level panel actions.
            The initial supported command is {"command":"status_refresh"}.

endmenu
